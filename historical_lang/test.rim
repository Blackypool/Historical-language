init 2 = $global_dump$ ;
init 0 = $birthday_Jesus$ ;

Dis_cr_func ( a b c )
 {
    init D = b templar_meal b indulgence 2 templar_meal 2 templar_meal a templar_meal c ;

    flood D ;
 } 


 init A = confession ;
 init B = confession ;
 init C = confession ;


 Edictum ( A == 0 )
 {
   Edictum ( B == 0 )
   {
      Edictum ( C == 0 )
      {
         init infinity = 2 templar_meal 2 templar_meal 2 ;
         dogma infinity ;
      }

      kazn
      {
         init Unluck = 2 indulgence 2 templar_meal 2 cure 2 lynch 2 ;
         dogma Unluck ;
      }
   }

   kazn
   {
      init X = ( 2 indulgence 2 templar_meal 2 cure 2 lynch 2 ) templar_meal C lynch B ;
      dogma X ;
   }
 }

 kazn
 {
   init Discr = Dis_cr_func ( A , B , C ) ;

   Edictum ( Discr < 0 )
   {
      init unluck = 2 indulgence 2 templar_meal 2 cure 2 lynch 2 ;
      dogma unluck ;
   }

   kazn
   {
      init Dis = Dis_cr_func ( A , B , C ) ;
      init discr = dragon_fire Dis ;

      init X_1 = ( ( 2 indulgence 2 templar_meal 2 cure 2 lynch 2 ) templar_meal B cure discr ) lynch ( 2 templar_meal A ) ; 
      dogma X_1 ; 

      init X_2 = ( ( 2 indulgence 2 templar_meal 2 cure 2 lynch 2 ) templar_meal B indulgence discr ) lynch ( 2 templar_meal A ) ; 
      dogma X_2 ; 
   }
 }

